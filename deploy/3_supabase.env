# ============================================================
# GLIVAC — Variables de entorno para Supabase self-hosted
# Ubicar en: /opt/glivac/supabase/.env
# IMPORTANTE: Cambiar TODOS los valores marcados con <CAMBIAR>
# ============================================================

# ── Dominio ──────────────────────────────────────────────────────────
SITE_URL=https://glivac.online
API_EXTERNAL_URL=https://glivac.online
ADDITIONAL_REDIRECT_URLS=

# ── Secretos JWT — GENERAR con: openssl rand -base64 64 ─────────────
# NUNCA compartir estos valores. Son la clave de toda la seguridad.
JWT_SECRET=<CAMBIAR: openssl rand -base64 64>
SECRET_KEY_BASE=<CAMBIAR: openssl rand -base64 64>
REALTIME_SECRET=<CAMBIAR: openssl rand -base64 32>

# ── PostgreSQL ───────────────────────────────────────────────────────
# Contraseña del usuario postgres principal
POSTGRES_PASSWORD=<CAMBIAR: contraseña segura, ej: openssl rand -base64 32>

# ── Email / SMTP (para confirmación de cuentas) ──────────────────────
# Si no tenés SMTP, activar GOTRUE_MAILER_AUTOCONFIRM=true en compose
SMTP_HOST=smtp.tuproveedor.com
SMTP_PORT=587
SMTP_USER=noreply@glivac.online
SMTP_PASS=<CAMBIAR: password del servidor de correo>
SMTP_ADMIN_EMAIL=admin@glivac.online

# ── Claves JWT para el frontend (generadas con el JWT_SECRET) ────────
# Ver script 4_generate_jwt_keys.sh para generarlas automáticamente
ANON_KEY=<CAMBIAR: generada con script 4>
SERVICE_ROLE_KEY=<CAMBIAR: generada con script 4>
