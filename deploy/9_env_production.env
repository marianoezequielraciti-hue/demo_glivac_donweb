# ============================================================
# GLIVAC — Variables de entorno del FRONTEND en producción
# Ubicar en: /opt/glivac/secrets/.env.production
# NUNCA commitear este archivo al repositorio
# ============================================================

# ── Supabase self-hosted (apunta al mismo servidor, vía Nginx) ──────
# Nginx enruta /auth/v1/ y /rest/v1/ a Kong (puerto 8000)
VITE_SUPABASE_URL=https://glivac.online

# La ANON_KEY se genera con el script 4_generate_jwt_keys.sh
# usando el mismo JWT_SECRET configurado en Supabase self-hosted
VITE_SUPABASE_ANON_KEY=<PEGAR_ANON_KEY_GENERADA_POR_SCRIPT_4>

# ── Admin emails (sin espacios, separados por coma) ─────────────────
VITE_SUPABASE_ADMIN_EMAILS=alignac@gmail.com,demoglivac@gmail.com,marianoezequielraciti@gmail.com,matias.0122.vazquez@gmail.com

# ── IA (opcionales — si no los usás, dejar vacíos) ──────────────────
VITE_ANTHROPIC_API_KEY=
VITE_GOOGLE_AI_STUDIO_API_KEY=

# ── NOTA IMPORTANTE ─────────────────────────────────────────────────
# La app ahora se conecta a https://glivac.online (este servidor)
# en vez de a Supabase Cloud.
# Las rutas internas son:
#   Auth:     https://glivac.online/auth/v1/
#   REST API: https://glivac.online/rest/v1/
#   Realtime: https://glivac.online/realtime/v1/
# Nginx hace proxy de estas rutas hacia Kong (localhost:8000)
# Kong enruta a GoTrue (auth) y PostgREST (rest)
