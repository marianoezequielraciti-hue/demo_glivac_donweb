# ============================================================
# GLIVAC — Variables de entorno para Hostinger Node.js
# Configurar en: hPanel → App web Node.js → Variables de entorno
# NUNCA commitear este archivo
# ============================================================

# ── Base de datos MySQL (Hostinger) ─────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=u652058863_glivac
DB_PASSWORD=TU_PASSWORD_MYSQL
DB_NAME=u652058863_glivac

# ── JWT (generar con: openssl rand -base64 64) ───────────────
JWT_SECRET=GENERAR_CON_OPENSSL_RAND_BASE64_64

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Variables del frontend (embebidas en el build de Vite) ──
# Estas deben estar disponibles ANTES de que Hostinger ejecute npm run build
# La app ya no usa Supabase Cloud — apunta a sí misma
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Emails admin ─────────────────────────────────────────────
VITE_SUPABASE_ADMIN_EMAILS=alignac@gmail.com,demoglivac@gmail.com,marianoezequielraciti@gmail.com
